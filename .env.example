# Copie este arquivo para ".env" e preencha com sua chave da Anthropic
# (crie em https://platform.claude.com > API Keys)
ANTHROPIC_API_KEY=

# Opcional: modelo usado pelo coach (padrão: claude-opus-4-8)
# CLAUDE_MODEL=claude-opus-4-8

# Opcional: gera imagem ilustrativa por exercício (Google AI Studio, requer plano pago)
# GEMINI_API_KEY=

# Opcional: porta do servidor (padrão: 8787)
# PORT=8787
