# Copie este arquivo para ".env" e preencha com sua chave da Anthropic
# (crie em https://platform.claude.com > API Keys)
ANTHROPIC_API_KEY=

# Opcional: modelo usado pelo coach (padrão: claude-opus-4-8)
# CLAUDE_MODEL=claude-opus-4-8

# Opcional: gera imagem ilustrativa por exercício (Google AI Studio, requer plano pago)
# GEMINI_API_KEY=

# Opcional: porta do servidor (padrão: 8787)
# PORT=8787

# Opcional: chaves VAPID pra notificação push (lembrete diário). Se não setar, o servidor gera
# um par na primeira vez que rodar e salva em data/vapid-keys.json — só precisa disso aqui se
# quiser controlar a chave manualmente (ex.: gerar com `npx web-push generate-vapid-keys`).
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
